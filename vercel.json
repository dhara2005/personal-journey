{
  "rewrites": [
    {
      "source": "/__/auth/:path(.*)",
      "destination": "https://quit-addiction-b9825.firebaseapp.com/__/auth/:path"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}